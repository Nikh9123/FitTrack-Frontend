{
  "expo": {
    "name": "Veera",
    "slug": "veera",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "veera",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070B14"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Veera uses the camera to capture InBody and body composition reports.",
        "NSPhotoLibraryUsageDescription": "Veera uses your photo library to upload existing InBody reports.",
        "NSMotionUsageDescription": "Veera uses motion data to track walking, running, and activity summaries.",
        "UIBackgroundModes": ["fetch", "processing"]
      }
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.sdeashirvad.veera"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://veera.ashirvad.work"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Veera uses the camera to capture InBody and body composition reports.",
          "photosPermission": "Veera uses your photo library to upload existing InBody reports.",
          "microphonePermission": false
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "expo-background-fetch",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B35",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "appUrl": "https://veera.ashirvad.work",
      "eas": {
        "projectId": "9f892c60-5fce-4f3e-be32-a34ac9f3c60b"
      }
    }
  }
}
